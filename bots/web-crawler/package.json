{
  "name": "mindle-web-crawler",
  "version": "1.0.0",
  "description": "Mindle Web Crawler — Puppeteer-based scraper for Naver Cafe/Blog",
  "main": "crawler.js",
  "scripts": {
    "start": "node crawler.js",
    "crawl:naver-cafe": "node crawler.js --target naver-cafe",
